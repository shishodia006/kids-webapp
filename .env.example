ANANTYA_WHATSAPP_API_URL=https://apiv1.anantya.ai/api/Campaign/SendSingleTemplateMessage
ANANTYA_WHATSAPP_API_KEY=replace-with-your-api-key
ANANTYA_OTP_TEMPLATE_ID=1062
ANANTYA_TEXT_TEMPLATE_ID=1063
# PHP helper compatible aliases are also supported:
# ANANTYA_API_KEY=replace-with-your-api-key
# ANANTYA_TEMPLATE_ID=1062
OTP_HASH_SECRET=replace-with-a-long-random-secret-at-least-32-chars
SESSION_SECRET=replace-with-another-long-random-secret-at-least-32-chars
KONNECT_LOGIN_CODE=replace-with-your-login-konnektkode
ADMIN_PHONE_NUMBERS=9811297908,9876543210
DB_HOST=localhost
DB_PORT=3306
DB_NAME=replace-with-database-name
DB_USER=replace-with-database-user
DB_PASSWORD=replace-with-database-password
DB_CHARSET=utf8mb4
DB_CONNECTION_LIMIT=10
# Current app database uses Supabase/PostgreSQL through Prisma:
DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:5432/postgres
# For Supabase local/dev, prefer the Session Pooler URL when direct db.<project>.supabase.co is IPv6-only.
RAZORPAY_KEY_ID=replace-with-razorpay-key-id
RAZORPAY_KEY_SECRET=replace-with-razorpay-key-secret
